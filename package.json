{
  "name": "glow-fix",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "db:reset": "turbo run db:reset --filter=server",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "db:migrate": "turbo run db:migrate --filter=@glow-fix/api",
    "db:seed": "turbo run db:seed --filter=@glow-fix/api",
    "db:studio": "turbo run db:studio --filter=@glow-fix/api",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') require('child_process').execSync('husky install')\""
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^1.13.4",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.1.0",
    "@vercel/node": "^5.8.8",
    "express": "^5.2.1",
    "nodemailer": "^8.0.7",
    "serverless-http": "^4.0.0"
  }
}

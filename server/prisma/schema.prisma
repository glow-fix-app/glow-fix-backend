// =============================================================================
// schema.prisma — Auto-generated from DBML
// Database: PostgreSQL (with PostGIS for geography columns)
// Generator: Prisma Client (JS/TS)
//
// onDelete / onUpdate strategy summary:
//   - Users are the root anchor. Deleting a user cascades to their sessions,
//     OTPs, and auth providers (identity data), but RESTRICTS on bookings,
//     businesses, payments, etc. (financial/operational records must be kept).
//   - Bookings cascade to their dependent child records (items, notes, status,
//     cancellations, diagnostics, payments, reviews, loyalty transactions).
//   - Businesses cascade to their operational children (services, hours,
//     documents, status history) but RESTRICT deletion while bookings exist.
//   - Lookup / reference rows (statuses, payment_methods, categories, services,
//     notification_types) use RESTRICT everywhere — they must not be deleted
//     while rows reference them.
//   - Audit logs always use SetNull on actor_id — logs must survive user deletion.
//   - onUpdate is Cascade everywhere (PK changes, though rare, should propagate).
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pgcrypto]
}

// =====================================================================
// ENUMS
// =====================================================================

enum UserRole {
  CLIENT
  MANAGER
  ADMIN

  @@map("user_role")
}

enum AuthProvider {
  EMAIL
  GOOGLE

  @@map("auth_provider")
}

enum BookingItemType {
  CATALOG_SERVICE
  REPAIR_ITEM

  @@map("booking_item_type")
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED

  @@map("loyalty_transaction_type")
}

enum OtpPurpose {
  PASSWORD_RESET
  PHONE_VERIFICATION
  EMAIL_VERIFICATION
  TWO_FACTOR

  @@map("otp_purpose")
}

enum FindingPriority {
  CRITICAL
  WARNING
  INFO

  @@map("finding_priority")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS

  @@map("notification_channel")
}

enum ConversationType {
  BOOKING
  SUPPORT
  GENERAL

  @@map("conversation_type")
}

enum ParticipantRole {
  CLIENT
  MANAGER
  ADMIN
  SYSTEM

  @@map("participant_role")
}

enum LogEntityType {
  USER
  BOOKING
  PAYMENT
  PAYOUT
  REVIEW
  DIAGNOSTIC_REPORT
  SERVICE
  BUSINESS
  BUSINESS_DOCUMENT

  @@map("log_entity_type")
}

enum LogAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  LOGIN
  LOGOUT
  APPROVED
  REJECTED
  SUSPENDED

  @@map("log_action")
}

// =====================================================================
// GLOBAL METADATA & LOOKUPS
// =====================================================================

/// Generic status registry shared across all entities.
/// Use the `context` field to filter statuses relevant to a specific domain
/// (e.g., context = 'BOOKING', 'PAYMENT', 'BUSINESS').
model Status {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Domain this status belongs to: 'BUSINESS' | 'DOCUMENT' | 'BOOKING' | 'PAYMENT' | 'CONVERSATION' | 'MESSAGE'
  context   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations — all RESTRICT: a status row must not be deleted while in use
  businessStatuses  BusinessStatus[]
  businessDocuments BusinessDocument[]
  payments          Payment[]
  payouts           Payout[]
  bookingStatuses   BookingStatus[]
  conversations     Conversation[]
  messages          Message[]

  @@map("statuses")
}

/// Predefined reasons for rejecting a business, document, or booking.
model RejectionReason {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  reasonText String   @map("reason_text")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("rejection_reasons")
}

/// Supported payment methods on the platform.
/// Disable methods without deleting them by toggling `isEnabled`.
model PaymentMethod {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  payments Payment[]

  @@map("payment_methods")
}

/// Polymorphic image store for all entities in the system.
/// entity_type values: 'USER_AVATAR' | 'BUSINESS_LOGO' | 'BUSINESS_COVER' |
///                     'BUSINESS_GALLERY' | 'BOOKING_PROBLEM' | 'CHAT_ATTACHMENT'
model Image {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url        String
  storageKey String?  @map("storage_key")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([entityType, entityId])
  @@map("images")
}

/// Global platform settings. Only one active row is expected.
model Setting {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Platform commission percentage charged per booking (e.g., 10.00 = 10%)
  businessFeePct   Decimal  @map("business_fee_pct")
  /// Maximum minutes before scheduled_at that a booking can be cancelled
  maxCancelMinutes Int      @map("max_cancel_minutes")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("settings")
}

// =====================================================================
// IDENTITY & SESSIONS
// =====================================================================

/// Central user account for all roles (CLIENT, MANAGER, ADMIN).
model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role             UserRole
  fullName         String    @map("full_name")
  email            String    @unique
  phone            String?   @unique
  passwordHash     String?   @map("password_hash")
  emailVerified    Boolean   @default(false) @map("email_verified")
  emailVerifiedAt   DateTime? @map("email_verified_at") @db.Timestamptz
  phoneVerified    Boolean   @default(false) @map("phone_verified")
  phoneVerifiedAt   DateTime? @map("phone_verified_at") @db.Timestamptz
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?   @map("two_factor_secret")
  isActive         Boolean   @default(true) @map("is_active")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Identity children — CASCADE: when a user is deleted, clean up their auth data
  authProviders UserAuthProvider[]
  otps          UserOtp[]
  sessions      UserSession[]

  // Profile — CASCADE: profile is meaningless without the user
  client Client?

  // Business ownership — RESTRICT: cannot delete a user who owns a business
  businesses Business[]

  // Operational references — RESTRICT by default (Prisma default for optional FKs)
  bookingCancellations     BookingCancellation[]
  sentNotifications        Notification[]            @relation("NotificationActor")
  receivedNotifications    Notification[]            @relation("NotificationRecipient")
  conversationParticipants ConversationParticipant[]
  messages                 Message[]
  auditLogs                AuditLog[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

/// Links a user to one or more authentication providers.
model UserAuthProvider {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  provider       AuthProvider
  providerUserId String?      @map("provider_user_id")
  email          String
  linkedAt       DateTime     @default(now()) @map("linked_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, provider])
  @@unique([provider, providerUserId])
  @@map("user_auth_providers")
}

/// Short-lived one-time passwords for verification and password reset flows.
model UserOtp {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  purpose   OtpPurpose
  codeHash  String     @map("code_hash")
  expiresAt DateTime   @map("expires_at") @db.Timestamptz
  usedAt    DateTime?  @map("used_at") @db.Timestamptz
  attempts  Int        @default(0) @db.SmallInt
  used      Boolean  @default(false)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("user_otps")
}

/// Active user sessions identified by a hashed refresh/session token.
model UserSession {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash")
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  lastUsedAt DateTime @default(now()) @map("last_used_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("user_sessions")
}

// =====================================================================
// CLIENTS
// =====================================================================

/// Extended profile for users with role = CLIENT.
model Client {
  id        String                               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String                               @unique @map("user_id") @db.Uuid
  /// Stored as PostGIS geography point. Null if the client hasn't set their location yet.
  /// Use Prisma.$queryRaw for spatial queries and updates.
  location  Unsupported("geography(Point,4326)")?
  city      String?
  createdAt DateTime                             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime                             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vehicles            ClientVehicle[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([location], type: Gist)
  @@map("clients")
}

/// Vehicles registered by a client.
model ClientVehicle {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  licensePlate String   @map("license_plate")
  model        String?
  year         Int?
  color        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // CASCADE: vehicles belong to the client profile; delete with it
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookings Booking[]

  @@unique([clientId, licensePlate])
  @@map("client_vehicles")
}

// =====================================================================
// BUSINESSES & CATALOG ENGINE
// =====================================================================

/// Core business (workshop) profile, created by a MANAGER user.
model Business {
  id           String                               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  managerId    String                               @map("manager_id") @db.Uuid
  businessName String                               @map("business_name")
  address      String
  city         String?
  /// Stored as PostGIS geography point.
  /// Use Prisma.$queryRaw for spatial queries and updates.
  location     Unsupported("geography(Point,4326)")
  contactPhone String?                              @map("contact_phone")
  contactEmail String?                              @map("contact_email")
  createdAt    DateTime                             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime                             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // RESTRICT: cannot delete a manager user while they own a business
  manager User @relation(fields: [managerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // CASCADE: operational children belong to the business
  statusHistory    BusinessStatus[]
  documents        BusinessDocument[]
  operatingHours   OperatingHour[]
  businessServices BusinessService[]
  bookings         Booking[]
  payouts          Payout[]

  @@index([location], type: Gist)
  @@map("businesses")
}

/// Tracks the status history of a business.
model BusinessStatus {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  statusId   String   @map("status_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // CASCADE: history rows belong to the business
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // RESTRICT: status lookup row must not be deleted while referenced
  status   Status   @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("business_status")
}

/// Documents submitted by a business for admin verification.
model BusinessDocument {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  /// 'BUSINESS_REGISTRATION' | 'INSURANCE_CERTIFICATE' | 'TAX_CARD'
  type       String
  url        String
  statusId   String   @map("status_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  status   Status   @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("business_documents")
}

/// Weekly operating schedule for a business.
/// One row per day of the week (0 = Sunday … 6 = Saturday).
/// Null open_time/close_time means the business is closed that day.
model OperatingHour {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  /// 0 = Sunday, 1 = Monday, …, 6 = Saturday
  dayOfWeek  Int      @map("day_of_week") @db.SmallInt
  openTime   String?  @map("open_time") // Stored as "HH:MM" string; use @db.Time if driver supports it
  closeTime  String?  @map("close_time") // Stored as "HH:MM" string
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([businessId, dayOfWeek])
  @@map("operating_hours")
}

/// Top-level grouping for services (e.g., 'Oil Change', 'Tires', 'Diagnostics').
model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  services Service[]

  @@map("categories")
}

/// Platform-level service definitions shared across all businesses.
model Service {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // RESTRICT: cannot delete a category that still has services
  category         Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  businessServices BusinessService[]

  @@map("services")
}

/// The catalog matrix — maps a business to the services it offers.
model BusinessService {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId      String   @map("business_id") @db.Uuid
  serviceId       String   @map("service_id") @db.Uuid
  /// Price in smallest currency unit (e.g., piastres)
  price           BigInt
  /// Estimated service time in minutes
  averageDuration Int      @map("average_duration")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // RESTRICT: cannot delete a business/service while catalog entries exist
  business           Business            @relation(fields: [businessId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  service            Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  bookingItems       BookingItem[]
  recommendedRepairs RecommendedRepair[]

  @@unique([businessId, serviceId])
  @@map("business_service")
}

// =====================================================================
// BOOKINGS & DIAGNOSTICS
// =====================================================================

/// Core booking record linking a client's vehicle to a business appointment.
/// All financial fields are in piastres (smallest currency unit).
model Booking {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId          String    @map("vehicle_id") @db.Uuid
  businessId         String    @map("business_id") @db.Uuid
  scheduledAt        DateTime  @map("scheduled_at") @db.Timestamptz
  expectedDeliveryAt DateTime? @map("expected_delivery_at") @db.Timestamptz
  subTotal           BigInt    @default(0) @map("sub_total")
  discount           BigInt    @default(0)
  commission         BigInt    @default(0)
  totalPrice         BigInt    @default(0) @map("total_price")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // RESTRICT: cannot delete a vehicle/business while bookings reference them
  vehicle  ClientVehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  business Business      @relation(fields: [businessId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // CASCADE: all booking-owned data is deleted with the booking
  statusHistory       BookingStatus[]
  cancellation        BookingCancellation?
  items               BookingItem[]
  notes               BookingNote[]
  diagnosticReport    DiagnosticReport?
  payment             Payment?
  review              Review?
  loyaltyTransactions LoyaltyTransaction[]
  payoutBookings      PayoutBooking[]
  conversation        Conversation[]

  @@map("bookings")
}

/// Append-only status history for a booking.
model BookingStatus {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  statusId  String   @map("status_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  status  Status  @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("booking_status")
}

/// Records the cancellation of a booking. One booking can only be cancelled once.
model BookingCancellation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId   String   @unique @map("booking_id") @db.Uuid
  cancelledBy String?  @map("cancelled_by") @db.Uuid
  cancelledAt DateTime @default(now()) @map("cancelled_at") @db.Timestamptz
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // SetNull: keep cancellation record even if the cancelling user is later deleted
  user    User?   @relation(fields: [cancelledBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("booking_cancellations")
}

/// Line items within a booking.
/// Prices are captured as snapshots at booking time.
model BookingItem {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId         String          @map("booking_id") @db.Uuid
  businessServiceId String          @map("business_service_id") @db.Uuid
  /// Price snapshot at the time of booking
  price             BigInt
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz

  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // RESTRICT: catalog entry must not be deleted while referenced by booking items (audit trail)
  businessService BusinessService @relation(fields: [businessServiceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("booking_items")
}

/// Internal notes added by the manager or admin during a booking's lifecycle.
model BookingNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("booking_notes")
}

/// Diagnostic inspection report created by the workshop after receiving the vehicle.
model DiagnosticReport {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId         String    @unique @map("booking_id") @db.Uuid
  summary           String
  validUntil        DateTime? @map("valid_until") @db.Timestamptz
  estimatedDuration Int?      @map("estimated_duration")
  /// 'accepted' | 'declined' — set when the client responds to the report
  clientAction      String?   @map("client_action")
  clientActionAt    DateTime? @map("client_action_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  booking            Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  findings           ReportFinding[]
  recommendedRepairs RecommendedRepair[]

  @@map("diagnostic_reports")
}

/// Individual issues found during a diagnostic inspection.
model ReportFinding {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId    String          @map("report_id") @db.Uuid
  title       String
  description String?
  priority    FindingPriority
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz

  report DiagnosticReport @relation(fields: [reportId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("report_findings")
}

/// Suggested repairs generated from a diagnostic report.
model RecommendedRepair {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId          String   @map("report_id") @db.Uuid
  businessServiceId String   @map("business_service_id") @db.Uuid
  title             String?
  description       String?
  /// Price in piastres (smallest currency unit)
  priceCents        BigInt   @default(0) @map("price_cents")
  durationMinutes   Int?     @map("duration_minutes")
  isSelected        Boolean  @default(false) @map("is_selected")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  report          DiagnosticReport @relation(fields: [reportId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // RESTRICT: catalog entry must not be deleted while recommended repairs reference it
  businessService BusinessService  @relation(fields: [businessServiceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("recommended_repairs")
}

// =====================================================================
// PAYMENTS & PAYOUTS
// =====================================================================

/// Records a payment made by a client for a booking.
model Payment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String   @unique @map("booking_id") @db.Uuid
  paymentMethodId String   @map("payment_method_id") @db.Uuid
  provider        String?
  providerRef     String?  @map("provider_ref")
  /// Amount charged in piastres
  amount          BigInt
  currency        String   @default("EGP") @db.Char(3)
  statusId        String   @map("status_id") @db.Uuid
  idempotencyKey  String?  @unique @map("idempotency_key")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // CASCADE: payment record is part of the booking lifecycle
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // RESTRICT: payment method / status lookup rows must not be deleted while referenced
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status        Status        @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("payments")
}

/// A payout settlement batch issued to a business owner.
model Payout {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId  String    @map("business_id") @db.Uuid
  /// Net payout amount in piastres (after platform fee)
  amount      BigInt
  statusId    String    @map("status_id") @db.Uuid
  processedAt DateTime? @map("processed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // RESTRICT: cannot delete a business while payouts exist
  business       Business        @relation(fields: [businessId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status         Status          @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  payoutBookings PayoutBooking[]

  @@map("payouts")
}

/// Junction table linking a payout to the individual bookings it covers.
model PayoutBooking {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payoutId  String   @map("payout_id") @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // CASCADE: payout junction rows are deleted when the payout is deleted
  payout  Payout  @relation(fields: [payoutId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // RESTRICT: cannot delete a booking that has been included in a payout
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([payoutId, bookingId])
  @@map("payout_bookings")
}

// =====================================================================
// LOYALTY PROGRAM
// =====================================================================

/// Active configuration for the loyalty points program.
model LoyaltyConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Points awarded for every 100 EGP spent
  pointsPer100Egp Int      @map("points_per_100_egp")
  /// EGP value of a single loyalty point when redeeming
  egpPerPoint     Decimal  @map("egp_per_point")
  /// Maximum % of a booking total that can be paid with points
  maxRedeemPct    Int      @map("max_redeem_pct")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("loyalty_config")
}

/// Ledger of all loyalty point movements per client.
model LoyaltyTransaction {
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String                 @map("client_id") @db.Uuid
  bookingId String?                @map("booking_id") @db.Uuid
  type      LoyaltyTransactionType
  /// Positive for EARNED, negative for REDEEMED
  points    Int
  reason    String
  createdAt DateTime               @default(now()) @map("created_at") @db.Timestamptz

  // RESTRICT: financial ledger — do not delete client/booking while transactions exist
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("loyalty_transactions")
}

// =====================================================================
// REVIEWS & COMMUNICATIONS
// =====================================================================

/// Post-service review submitted by the client after a booking is completed.
model Review {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId           String   @unique @map("booking_id") @db.Uuid
  /// Overall rating (1–5)
  rating              Int      @db.SmallInt
  qualityRating       Int?     @map("quality_rating") @db.SmallInt
  punctualityRating   Int?     @map("punctuality_rating") @db.SmallInt
  communicationRating Int?     @map("communication_rating") @db.SmallInt
  comment             String?
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // CASCADE: review is part of the booking record
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("reviews")
}

/// Lookup table for notification types.
model NotificationType {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Machine-readable key (e.g., 'BOOKING_CONFIRMED')
  code      String   @unique
  /// Human-readable name (e.g., 'Booking Confirmed')
  label     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  notifications Notification[]

  @@map("notification_types")
}

/// Individual notification records sent to a user.
model Notification {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientUserId String    @map("recipient_user_id") @db.Uuid
  actorUserId     String?   @map("actor_user_id") @db.Uuid
  typeId          String    @map("type_id") @db.Uuid
  title           String
  body            String?
  actionUrl       String?   @map("action_url")
  readAt          DateTime? @map("read_at") @db.Timestamptz
  sentAt          DateTime? @map("sent_at") @db.Timestamptz
  failedReason    String?   @map("failed_reason")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // CASCADE: notifications are owned by the recipient
  recipient User             @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // SetNull: keep notification record even if the actor user is deleted
  actor     User?            @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  // RESTRICT: notification type lookup must not be deleted while referenced
  type      NotificationType @relation(fields: [typeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("notifications")
}

/// A chat thread, optionally linked to a booking.
model Conversation {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String?          @map("booking_id") @db.Uuid
  type      ConversationType @default(BOOKING)
  statusId  String           @map("status_id") @db.Uuid
  closedAt  DateTime?        @map("closed_at") @db.Timestamptz
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // SetNull: conversation can exist as a support/general thread without a booking
  booking      Booking?                  @relation(fields: [bookingId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status       Status                    @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

/// Users who are part of a conversation thread.
model ConversationParticipant {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String          @map("conversation_id") @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  role           ParticipantRole
  lastReadAt     DateTime?       @map("last_read_at") @db.Timestamptz
  joinedAt       DateTime        @default(now()) @map("joined_at") @db.Timestamptz
  leftAt         DateTime?       @map("left_at") @db.Timestamptz

  // CASCADE: participant records belong to the conversation
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // RESTRICT: cannot delete a user who is still an active participant
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("conversation_participants")
}

/// Individual messages within a conversation.
model Message {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String          @map("conversation_id") @db.Uuid
  senderUserId   String?         @map("sender_user_id") @db.Uuid
  senderRole     ParticipantRole @default(SYSTEM) @map("sender_role")
  /// 'TEXT' | 'IMAGE' | 'FILE'
  type           String          @default("TEXT")
  body           String?
  statusId       String          @map("status_id") @db.Uuid
  deliveredAt    DateTime?       @map("delivered_at") @db.Timestamptz
  readAt         DateTime?       @map("read_at") @db.Timestamptz
  editedAt       DateTime?       @map("edited_at") @db.Timestamptz
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // CASCADE: messages belong to the conversation
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // SetNull: keep message record even if the sender is deleted; senderRole preserves context
  sender       User?        @relation(fields: [senderUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status       Status       @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("messages")
}

// =====================================================================
// AUDIT SYSTEM
// =====================================================================

/// Immutable event log for compliance, debugging, and change tracking.
model AuditLog {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?       @map("actor_id") @db.Uuid
  entityType LogEntityType @map("entity_type")
  entityId   String        @map("entity_id") @db.Uuid
  action     LogAction
  /// State of the record before the change (null for CREATED)
  oldData    Json?         @map("old_data") @db.JsonB
  /// State of the record after the change (null for DELETED)
  newData    Json?         @map("new_data") @db.JsonB
  ipAddress  String?       @map("ip_address")
  userAgent  String?       @map("user_agent")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz

  // SetNull: audit logs must survive user deletion — never cascade/restrict here
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("audit_logs")
}

# ─── Application ───
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3002

# ─── Database ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=glowfix_dev
DB_USER=glowfix
DB_PASSWORD=your_db_password
DB_SSL=false
DB_LOGGING=true
DATABASE_URL=postgresql://glowfix:your_db_password@localhost:5432/glowfix_dev
SHADOW_DATABASE_URL=postgresql://glowfix:your_db_password@localhost:5432/glowfix_shadow

# ─── Test Database ───
DB_TEST_HOST=localhost
DB_TEST_PORT=5433
DB_TEST_NAME=glowfix_test
DB_TEST_USER=glowfix
DB_TEST_PASSWORD=your_db_password
DATABASE_TEST_URL=postgresql://glowfix:your_db_password@localhost:5433/glowfix_test

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string-for-production
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OTP ───
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# ─── Storage (Cloudflare R2) ───
STORAGE_ENDPOINT=https://a8c0923c01fe3feaed641bea3a92ae18.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=glowfix-media
STORAGE_KEY_ID=your_access_key_id
STORAGE_KEY_SECRET=your_secret_access_key
STORAGE_CDN_BASE=https://pub-623fbd1a7d7249c287cd564e6a567f5e.r2.dev

# ─── Email (MailHog locally) ───
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@glowfix.local
SENDGRID_API_KEY=             # fill in for real email

# ─── Twilio (OTP/SMS) ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Google OAuth (required for Sign in with Google) ───
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Rate Limiting & Auth ───
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_OTP_COOLDOWN_SECONDS=60
AUTH_MFA_WINDOW=1
AUTH_MFA_TOKEN_EXPIRY=300

# ─── Monitoring ───
SENTRY_DSN=
LOG_LEVEL=debug

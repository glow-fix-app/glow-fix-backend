    "db:migrate:revert": "ts-node -r tsconfig-paths/register src/database/revert-migration.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeds/index.ts",
    "db:reset": "ts-node -r tsconfig-paths/register src/database/reset.ts",
    "clean": "rm -rf dist coverage"

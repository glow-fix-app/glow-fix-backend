  updatedAt         DateTime @updatedAt @map("updated_at")

  category  ProductCategory? @relation(fields: [categoryId], references: [id])
  cartItems CartItem[]

  @@index([categoryId])
  @@index([slug])
  @@index([isActive, isFeatured])
  @@map("products")
}


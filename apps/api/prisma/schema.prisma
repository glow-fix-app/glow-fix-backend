generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto, postgis]
}

// ──────────────────────────────────────────
// CUSTOMER
// ──────────────────────────────────────────
model Customer {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fullName          String    @map("full_name") @db.VarChar(100)
  mobileNumber      String    @unique @map("mobile_number") @db.VarChar(20)
  email             String    @unique @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  birthdate         DateTime? @db.Date
  profilePhotoUrl   String?   @map("profile_photo_url") @db.VarChar(500)
  homeLocationLat   Float?    @map("home_location_lat")
  homeLocationLng   Float?    @map("home_location_lng")
  loyaltyPoints     Int       @default(0) @map("loyalty_points")
  totalSpent        Int       @default(0) @map("total_spent") // in cents
  marketingConsent  Boolean   @default(false) @map("marketing_consent")
  emailVerified     Boolean   @default(false) @map("email_verified")
  mobileVerified    Boolean   @default(false) @map("mobile_verified")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?   @map("two_factor_secret") @db.VarChar(255)
  referralCode      String    @unique @map("referral_code") @db.VarChar(20)
  referredBy        String?   @map("referred_by") @db.Uuid
  lastActiveAt      DateTime  @default(now()) @map("last_active_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  // Relations
  vehicles              Vehicle[]
  bookings              Booking[]
  loyaltyTransactions   LoyaltyTransaction[]
  reviews               Review[]
  savedPaymentMethods   SavedPaymentMethod[]
  subscriptions         Subscription[]
  notifications         Notification[]
  chatConversations     ChatConversation[]
  referrals             Referral[]          @relation("Referrer")
  referredByReferral    Referral?           @relation("Referee")
  warrantyClaims        WarrantyClaim[]
  oauthAccounts         OAuthAccount[]
  sessions              Session[]
  notificationPrefs     NotificationPreference?

  @@index([email])
  @@index([mobileNumber])
  @@index([referralCode])
  @@index([deletedAt])
  @@map("customers")
}

// ──────────────────────────────────────────
// OAUTH ACCOUNTS
// ──────────────────────────────────────────
model OAuthAccount {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  provider     String   @db.VarChar(20) // google, apple, facebook
  providerId   String   @map("provider_id") @db.VarChar(255)
  accessToken  String?  @map("access_token") @db.Text
  refreshToken String?  @map("refresh_token") @db.Text
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([customerId])
  @@map("oauth_accounts")
}

// ──────────────────────────────────────────
// SESSION
// ──────────────────────────────────────────
model Session {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  userType       String   @map("user_type") @db.VarChar(20) // CUSTOMER, STAFF, ADMIN
  refreshToken   String   @unique @map("refresh_token") @db.VarChar(500)
  deviceType     String?  @map("device_type") @db.VarChar(20)
  browser        String?  @db.VarChar(50)
  os             String?  @db.VarChar(50)
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.Text
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  customer Customer? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, userType])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

// ──────────────────────────────────────────
// NOTIFICATION PREFERENCE
// ──────────────────────────────────────────
model NotificationPreference {
  id                    String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId            String  @unique @map("customer_id") @db.Uuid
  emailEnabled          Boolean @default(true) @map("email_enabled")
  smsEnabled            Boolean @default(true) @map("sms_enabled")
  whatsappEnabled       Boolean @default(false) @map("whatsapp_enabled")
  pushEnabled           Boolean @default(true) @map("push_enabled")
  inAppEnabled          Boolean @default(true) @map("in_app_enabled")
  marketingFrequency    String  @default("weekly") @map("marketing_frequency") @db.VarChar(20) // immediate, daily, weekly, never
  quietHoursEnabled     Boolean @default(false) @map("quiet_hours_enabled")
  quietHoursStart       String? @map("quiet_hours_start") @db.VarChar(5) // "22:00"
  quietHoursEnd         String? @map("quiet_hours_end") @db.VarChar(5)   // "08:00"
  updatedAt             DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ──────────────────────────────────────────
// VEHICLE
// ──────────────────────────────────────────
model Vehicle {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  licensePlate String    @map("license_plate") @db.VarChar(20)
  make         String    @db.VarChar(50)
  model        String    @db.VarChar(50)
  year         Int
  color        String?   @db.VarChar(30)
  nickname     String?   @db.VarChar(50)
  isDefault    Boolean   @default(false) @map("is_default")
  photoUrl     String?   @map("photo_url") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  inspections Inspection[]

  @@unique([customerId, licensePlate])
  @@index([customerId])
  @@map("vehicles")
}

// ──────────────────────────────────────────
// CAR WASH
// ──────────────────────────────────────────
model CarWash {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String   @db.VarChar(100)
  address         String   @db.VarChar(255)
  latitude        Float
  longitude       Float
  phone           String   @db.VarChar(20)
  email           String   @db.VarChar(255)
  description     String?  @db.Text
  photos          String[] @default([])
  averageRating   Float    @default(0) @map("average_rating")
  totalReviews    Int      @default(0) @map("total_reviews")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  operatingHours  OperatingHours[]
  services        Service[]
  addOns          AddOn[]
  bookings        Booking[]
  reviews         Review[]
  staff           StaffAssignment[]
  favorites       Favorite[]

  @@index([latitude, longitude])
  @@index([isActive])
  @@map("car_washes")
}

// ──────────────────────────────────────────
// OPERATING HOURS
// ──────────────────────────────────────────
model OperatingHours {
  id         String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  carWashId  String  @map("car_wash_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week") // 0 = Sunday
  openTime   String  @map("open_time") @db.VarChar(5)  // "08:00"
  closeTime  String  @map("close_time") @db.VarChar(5) // "18:00"
  isClosed   Boolean @default(false) @map("is_closed")

  carWash CarWash @relation(fields: [carWashId], references: [id], onDelete: Cascade)

  @@unique([carWashId, dayOfWeek])
  @@map("operating_hours")
}

// ──────────────────────────────────────────
// FAVORITE
// ──────────────────────────────────────────
model Favorite {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  carWashId  String   @map("car_wash_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  carWash CarWash @relation(fields: [carWashId], references: [id], onDelete: Cascade)

  @@unique([customerId, carWashId])
  @@map("favorites")
}

// ──────────────────────────────────────────
// SERVICE
// ──────────────────────────────────────────
model Service {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  carWashId       String   @map("car_wash_id") @db.Uuid
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  type            String   @db.VarChar(20) // WASH, POLISH, DETAILING, COMBO
  durationMinutes Int      @map("duration_minutes")
  basePrice       Int      @map("base_price") // in cents
  peakPrice       Int?     @map("peak_price") // in cents
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  carWash         CarWash          @relation(fields: [carWashId], references: [id], onDelete: Cascade)
  bookingServices BookingService[]

  @@index([carWashId, type])
  @@index([isActive])
  @@map("services")
}

// ──────────────────────────────────────────
// ADD-ON
// ──────────────────────────────────────────
model AddOn {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  carWashId       String   @map("car_wash_id") @db.Uuid
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  price           Int      // in cents
  durationMinutes Int      @map("duration_minutes")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  carWash         CarWash          @relation(fields: [carWashId], references: [id], onDelete: Cascade)
  bookingAddOns   BookingAddOn[]

  @@index([carWashId])
  @@map("add_ons")
}

// ──────────────────────────────────────────
// BOOKING
// ──────────────────────────────────────────
model Booking {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId         String    @map("customer_id") @db.Uuid
  vehicleId          String    @map("vehicle_id") @db.Uuid
  carWashId          String    @map("car_wash_id") @db.Uuid
  scheduledTime      DateTime  @map("scheduled_time")
  estimatedDuration  Int       @map("estimated_duration") // minutes
  actualDuration     Int?      @map("actual_duration") // minutes
  queuePosition      Int?      @map("queue_position")
  currentStage       String?   @map("current_stage") @db.VarChar(30)
  status             String    @default("PENDING") @db.VarChar(20)
  paymentMethod      String    @map("payment_method") @db.VarChar(20)
  paymentStatus      String    @default("PENDING") @map("payment_status") @db.VarChar(20)
  totalAmount        Int       @map("total_amount") // in cents
  discountAmount     Int       @default(0) @map("discount_amount") // in cents
  loyaltyPointsUsed  Int       @default(0) @map("loyalty_points_used")
  loyaltyPointsEarned Int?     @map("loyalty_points_earned")
  promoCodeId        String?   @map("promo_code_id") @db.Uuid
  beforePhotos       String[]  @default([]) @map("before_photos")
  afterPhotos        String[]  @default([]) @map("after_photos")
  cancellationReason String?   @map("cancellation_reason") @db.Text
  cancelledAt        DateTime? @map("cancelled_at")
  completedAt        DateTime? @map("completed_at")
  idempotencyKey     String    @unique @map("idempotency_key") @db.VarChar(100)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  customer           Customer           @relation(fields: [customerId], references: [id])
  vehicle            Vehicle            @relation(fields: [vehicleId], references: [id])
  carWash            CarWash            @relation(fields: [carWashId], references: [id])
  promoCode          PromoCode?         @relation(fields: [promoCodeId], references: [id])
  bookingServices    BookingService[]
  bookingAddOns      BookingAddOn[]
  staffAssignments   StaffAssignment[]
  inspection         Inspection?
  review             Review?
  payment            Payment?
  warranty           Warranty?
  warrantyClaims     WarrantyClaim[]
  loyaltyTransactions LoyaltyTransaction[]
  chatConversation   ChatConversation?
  statusHistory      BookingStatusHistory[]

  @@index([customerId, status])
  @@index([carWashId, scheduledTime])
  @@index([status])
  @@index([scheduledTime])
  @@index([paymentStatus])
  @@map("bookings")
}

// ──────────────────────────────────────────
// BOOKING SERVICE (junction)
// ──────────────────────────────────────────
model BookingService {
  id        String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId String @map("booking_id") @db.Uuid
  serviceId String @map("service_id") @db.Uuid
  price     Int    // in cents (captured at booking time)
  quantity  Int    @default(1)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
  @@map("booking_services")
}

// ──────────────────────────────────────────
// BOOKING ADD-ON (junction)
// ──────────────────────────────────────────
model BookingAddOn {
  id        String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId String @map("booking_id") @db.Uuid
  addOnId   String @map("add_on_id") @db.Uuid
  price     Int    // in cents (captured at booking time)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOn   AddOn   @relation(fields: [addOnId], references: [id])

  @@unique([bookingId, addOnId])
  @@map("booking_add_ons")
}

// ──────────────────────────────────────────
// BOOKING STATUS HISTORY
// ──────────────────────────────────────────
model BookingStatusHistory {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId  String   @map("booking_id") @db.Uuid
  fromStatus String?  @map("from_status") @db.VarChar(20)
  toStatus   String   @map("to_status") @db.VarChar(20)
  stage      String?  @db.VarChar(30)
  changedBy  String?  @map("changed_by") @db.Uuid
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_status_history")
}

// ──────────────────────────────────────────
// STAFF
// ──────────────────────────────────────────
model Staff {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fullName          String    @map("full_name") @db.VarChar(100)
  mobileNumber      String    @unique @map("mobile_number") @db.VarChar(20)
  email             String    @unique @db.VarChar(255)
  passwordHash      String    @map("password_hash") @db.VarChar(255)
  licenseNumber     String    @map("license_number") @db.VarChar(50)
  specialties       String[]  @default([])
  profilePhotoUrl   String?   @map("profile_photo_url") @db.VarChar(500)
  hourlyRate        Int       @map("hourly_rate") // in cents
  isActive          Boolean   @default(true) @map("is_active")
  averageRating     Float     @default(0) @map("average_rating")
  totalJobsCompleted Int      @default(0) @map("total_jobs_completed")
  mustChangePassword Boolean  @default(true) @map("must_change_password")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  assignments       StaffAssignment[]
  inspections       Inspection[]
  availability      StaffAvailability[]
  timeOffRequests   TimeOffRequest[]
  chatConversations ChatConversation[] @relation("StaffChats")

  @@index([email])
  @@index([isActive])
  @@map("staff")
}

// ──────────────────────────────────────────
// STAFF ASSIGNMENT
// ──────────────────────────────────────────
model StaffAssignment {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId       String    @map("booking_id") @db.Uuid
  staffId         String    @map("staff_id") @db.Uuid
  carWashId       String    @map("car_wash_id") @db.Uuid
  status          String    @default("ASSIGNED") @db.VarChar(20) // ASSIGNED, IN_PROGRESS, COMPLETED, TRANSFERRED
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMinutes Int?      @map("duration_minutes")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  booking  Booking @relation(fields: [bookingId], references: [id])
  staff    Staff   @relation(fields: [staffId], references: [id])
  carWash  CarWash @relation(fields: [carWashId], references: [id])

  @@index([staffId, status])
  @@index([bookingId])
  @@map("staff_assignments")
}

// ──────────────────────────────────────────
// STAFF AVAILABILITY
// ──────────────────────────────────────────
model StaffAvailability {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  staffId     String  @map("staff_id") @db.Uuid
  dayOfWeek   Int     @map("day_of_week")
  startTime   String  @map("start_time") @db.VarChar(5)
  endTime     String  @map("end_time") @db.VarChar(5)
  isAvailable Boolean @default(true) @map("is_available")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@map("staff_availability")
}

// ──────────────────────────────────────────
// TIME OFF REQUEST
// ──────────────────────────────────────────
model TimeOffRequest {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  staffId     String    @map("staff_id") @db.Uuid
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime  @map("end_date") @db.Date
  reason      String    @db.Text
  status      String    @default("PENDING") @db.VarChar(20) // PENDING, APPROVED, REJECTED
  processedBy String?   @map("processed_by") @db.Uuid
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, status])
  @@map("time_off_requests")
}

// ──────────────────────────────────────────
// INSPECTION (DIVR)
// ──────────────────────────────────────────
model Inspection {
  id                    String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId             String   @unique @map("booking_id") @db.Uuid
  staffId               String   @map("staff_id") @db.Uuid
  vehicleId             String   @map("vehicle_id") @db.Uuid
  inspectionTime        DateTime @default(now()) @map("inspection_time")
  issues                Json     @default("[]")
  customerAcknowledged  Boolean  @default(false) @map("customer_acknowledged")
  customerSignature     String?  @map("customer_signature") @db.Text // base64
  pdfUrl                String?  @map("pdf_url") @db.VarChar(500)
  createdAt             DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  staff   Staff   @relation(fields: [staffId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("inspections")
}

// ──────────────────────────────────────────
// REVIEW
// ──────────────────────────────────────────
model Review {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId           String    @unique @map("booking_id") @db.Uuid
  customerId          String    @map("customer_id") @db.Uuid
  carWashId           String    @map("car_wash_id") @db.Uuid
  qualityRating       Int       @map("quality_rating") // 1-5
  speedRating         Int       @map("speed_rating") // 1-5
  staffRating         Int       @map("staff_rating") // 1-5
  overallRating       Float     @map("overall_rating") // calculated average
  comment             String?   @db.Text
  photos              String[]  @default([])
  staffResponse       String?   @map("staff_response") @db.Text
  staffRespondedAt    DateTime? @map("staff_responded_at")
  isVisible           Boolean   @default(true) @map("is_visible")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  booking  Booking  @relation(fields: [bookingId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  carWash  CarWash  @relation(fields: [carWashId], references: [id])

  @@index([carWashId, overallRating])
  @@index([customerId])
  @@map("reviews")
}

// ──────────────────────────────────────────
// PAYMENT
// ──────────────────────────────────────────
model Payment {
  id                    String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId             String    @unique @map("booking_id") @db.Uuid
  customerId            String    @map("customer_id") @db.Uuid
  amount                Int       // in cents
  currency              String    @default("USD") @db.VarChar(3)
  method                String    @db.VarChar(20)
  status                String    @default("PENDING") @db.VarChar(20)
  stripePaymentIntentId String?   @unique @map("stripe_payment_intent_id") @db.VarChar(255)
  paypalOrderId         String?   @unique @map("paypal_order_id") @db.VarChar(255)
  refundAmount          Int?      @map("refund_amount")
  refundReason          String?   @map("refund_reason") @db.Text
  refundedAt            DateTime? @map("refunded_at")
  refundedBy            String?   @map("refunded_by") @db.Uuid
  metadata              Json?     @default("{}")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("payments")
}

// ──────────────────────────────────────────
// SAVED PAYMENT METHOD
// ──────────────────────────────────────────
model SavedPaymentMethod {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  provider    String   @db.VarChar(20) // stripe, paypal
  token       String   @db.VarChar(255) // provider token ID
  last4       String   @db.VarChar(4)
  brand       String   @db.VarChar(20) // visa, mastercard
  expiryMonth Int      @map("expiry_month")
  expiryYear  Int      @map("expiry_year")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("saved_payment_methods")
}
  // ──────────────────────────────────────────
// LOYALTY TRANSACTION
// ──────────────────────────────────────────
model LoyaltyTransaction {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  bookingId   String?   @map("booking_id") @db.Uuid
  points      Int       // positive = earned, negative = redeemed
  type        String    @db.VarChar(20) // EARNED, REDEEMED, EXPIRED, BONUS, REFERRAL
  description String    @db.VarChar(255)
  expiryDate  DateTime? @map("expiry_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])


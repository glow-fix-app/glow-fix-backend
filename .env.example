# ─── Application ───
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3001
API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# ─── Database ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=glowfix_dev
DB_USER=glowfix
DB_PASSWORD=glowfix_dev_password
DB_SSL=false
DB_LOGGING=true
DATABASE_URL=postgresql://glowfix:glowfix_dev_password@localhost:5432/glowfix_dev

# ─── Test Database ───
DB_TEST_HOST=localhost
DB_TEST_PORT=5433
DB_TEST_NAME=glowfix_test
DB_TEST_USER=glowfix
DB_TEST_PASSWORD=glowfix_dev_password
DATABASE_TEST_URL=postgresql://glowfix:glowfix_dev_password@localhost:5433/glowfix_test

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=glowfix_redis_password
REDIS_DB=0
REDIS_URL=redis://:glowfix_redis_password@localhost:6379/0

# ─── JWT ───
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string-for-production
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OTP ───
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# ─── AWS / Storage ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET_NAME=glowfix-dev
S3_ENDPOINT=http://localhost:9000  # MinIO locally, remove in prod

# ─── Email (MailHog locally) ───
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@glowfix.local
SENDGRID_API_KEY=             # fill in for real email

# ─── Twilio (OTP/SMS) ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Google ───
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Rate Limiting & Auth ───
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_OTP_COOLDOWN_SECONDS=60
AUTH_MFA_WINDOW=1
AUTH_MFA_TOKEN_EXPIRY=300

# ─── Monitoring ───
SENTRY_DSN=
LOG_LEVEL=debug
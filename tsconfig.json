{
  "compilerOptions": {
    "baseUrl": ".",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@glow-fix/types": ["packages/types/src/index.ts"],
      "@glow-fix/utils": ["packages/utils/src/index.ts"],
      "@glow-fix/config": ["packages/config"]
    }
  },
  "references": [
    { "path": "packages/types" },
    { "path": "packages/utils" },
    { "path": "apps/api" }
  ],
  "files": []
}


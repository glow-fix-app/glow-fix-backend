{
  "extends": "@glow-fix/config/typescript/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "src/main.ts",
    "src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
